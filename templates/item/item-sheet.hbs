<form class="ogre-gate-form item" autocomplete="off">
  <header class="sheet-header item-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" data-action="showPortraitArtwork" title="{{item.name}}" />
    <section class="item-summary">
      <label>Name <input type="text" name="name" value="{{item.name}}" /></label>
      <label>Type <input type="text" value="{{item.type}}" disabled /></label>
      <label>Source <input type="text" name="system.source" value="{{system.source}}" /></label>
      {{#unless (eq item.type "technique")}}
        <label>Cost <input type="text" name="system.cost" value="{{system.cost}}" /></label>
      {{/unless}}
    </section>
  </header>

  {{#if (eq item.type "weapon")}}
    <section class="panel weapon-fields">
      <h2>Weapon</h2>
      <label data-tooltip="{{help.weaponCategory}}">Category
        <select name="system.category">
          {{#each combatSkills as |skill|}}
            <option value="{{skill.key}}" {{#if (eq ../system.category skill.key)}}selected{{/if}}>{{skill.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.attackSkill}}">Attack Skill
        <select name="system.attackSkill">
          {{#each combatSkills as |skill|}}
            <option value="{{skill.key}}" {{#if (eq ../system.attackSkill skill.key)}}selected{{/if}}>{{skill.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.targetDefense}}">Target Defense
        <select name="system.targetDefense">
          {{#each defenses as |defense|}}
            <option value="{{defense.key}}" {{#if (eq ../system.targetDefense defense.key)}}selected{{/if}}>{{defense.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.damageSkill}}">Damage Skill
        <select name="system.damageSkill">
          {{#each weaponDamageSkills as |skill|}}
            <option value="{{skill.key}}" {{#if skill.selected}}selected{{/if}}>{{skill.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.damageDice}}">Damage Bonus Dice <input type="number" name="system.damageDice" value="{{system.damageDice}}" min="-1" max="10" /></label>
      <label data-tooltip="{{help.accuracyModifier}}">Accuracy <input type="number" name="system.accuracyModifier" value="{{system.accuracyModifier}}" min="-10" max="10" /></label>
      <label data-tooltip="{{help.wieldedWeapon}}">Wielded <input type="checkbox" name="system.equipped" {{checked system.equipped}} /></label>
      <label data-tooltip="{{help.weaponDefenseBonus}}">Parry Bonus <input type="number" name="system.parryBonus" value="{{system.parryBonus}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.weaponDefenseBonus}}">Evade Bonus <input type="number" name="system.evadeBonus" value="{{system.evadeBonus}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.muscleRequirement}}">Muscle Requirement <input type="number" name="system.muscleRequirement" value="{{system.muscleRequirement}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.damageType}}">Damage Type
        <select name="system.damageType">
          {{#each weaponDamageTypes as |type|}}
            <option value="{{type.key}}" {{#if (eq ../system.damageType type.key)}}selected{{/if}}>{{type.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.weaponReach}}">Reach
        <select name="system.reach">
          {{#each reachOptions as |reach|}}
            <option value="{{reach.key}}" {{#if (eq ../system.reach reach.key)}}selected{{/if}}>{{reach.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.openDamage}}">Open Damage <input type="checkbox" name="system.openDamage" {{checked system.openDamage}} /></label>
      <label data-tooltip="{{help.lethal}}">Lethal <input type="checkbox" name="system.lethal" {{checked system.lethal}} /></label>
      <label data-tooltip="{{help.specialRules}}">Special Rules <input type="text" name="system.qualities" value="{{system.qualities}}" /></label>
    </section>
  {{/if}}

  {{#if (eq item.type "skills")}}
    <section class="panel">
      <h2>Skills</h2>
      <label data-tooltip="{{help.skillGroup}}">Primary Skill Type
        <select name="system.group">
          {{#each skillGroups as |group|}}
            <option value="{{group.key}}" {{#if (eq ../system.group group.key)}}selected{{/if}}>{{group.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.skillKey}}">Rules Key <input type="text" name="system.skillKey" value="{{system.skillKey}}" placeholder="speed, muscle, medicine..." /></label>
      <label>Ranks <input type="number" name="system.ranks" value="{{system.ranks}}" min="0" max="10" /></label>
      <label>Modifier <input type="number" name="system.modifier" value="{{system.modifier}}" min="-10" max="10" /></label>
      <label>Drain <input type="number" name="system.drain" value="{{system.drain}}" min="0" max="20" /></label>
      <label>Expertise <input type="text" name="system.expertise" value="{{system.expertise}}" /></label>
      <label>Expertise Note <input type="text" name="system.expertiseNote" value="{{system.expertiseNote}}" /></label>
    </section>
  {{/if}}

  {{#if (eq item.type "technique")}}
    <section class="panel weapon-fields">
      <h2>Kung Fu Technique</h2>
      <label data-tooltip="{{help.techniqueDiscipline}}">Discipline
        <select name="system.discipline">
          {{#each disciplines as |discipline|}}
            <option value="{{discipline.key}}" {{#if (eq ../system.discipline discipline.key)}}selected{{/if}}>{{discipline.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.techniqueType}}">Type
        <select name="system.techniqueType">
          {{#each techniqueTypes as |type|}}
            <option value="{{type.key}}" {{#if (eq ../system.techniqueType type.key)}}selected{{/if}}>{{type.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.qiRank}}">Qi Rank <input type="number" name="system.qiRank" value="{{system.qiRank}}" min="0" /></label>
      <label data-tooltip="{{help.techniqueTargetDefense}}">Rolled Against
        <select name="system.targetDefense">
          {{#each techniqueTargets as |target|}}
            <option value="{{target.key}}" {{#if target.selected}}selected{{/if}}>{{target.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.techniqueTargetNumber}}">Default TN <input type="number" name="system.targetNumber" value="{{system.targetNumber}}" min="0" max="20" /></label>
      <label data-tooltip="{{help.activationSkill}}">Activation Skill
        <select name="system.activationSkill">
          {{#each allSkills as |skill|}}
            <option value="{{skill.key}}" {{#if skill.selected}}selected{{/if}}>{{skill.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.techniqueAttackModifier}}">Attack Modifier <input type="number" name="system.attackModifier" value="{{system.attackModifier}}" min="-10" max="10" /></label>
      <label>Damage <input type="text" name="system.damage" value="{{system.damage}}" /></label>
      <label data-tooltip="{{help.techniqueDamageModifier}}">Damage Modifier <input type="number" name="system.damageModifier" value="{{system.damageModifier}}" min="-10" max="10" /></label>
      <label data-tooltip="{{help.directWounds}}">Direct Wounds <input type="text" name="system.directWounds" value="{{system.directWounds}}" /></label>
      <label data-tooltip="{{help.directWounds}}">Total Success Direct Wounds <input type="text" name="system.totalSuccessDirectWounds" value="{{system.totalSuccessDirectWounds}}" /></label>
      <label data-tooltip="{{help.targetDrains}}">Target Drain <input type="text" name="system.targetDrains" value="{{system.targetDrains}}" /></label>
      <label data-tooltip="{{help.targetDrains}}">Total Success Target Drain <input type="text" name="system.totalSuccessTargetDrains" value="{{system.totalSuccessTargetDrains}}" /></label>
      <label data-tooltip="{{help.targetEffects}}">Target Effect <input type="text" name="system.targetEffects" value="{{system.targetEffects}}" /></label>
      <label data-tooltip="{{help.targetEffects}}">Total Success Target Effect <input type="text" name="system.totalSuccessTargetEffects" value="{{system.totalSuccessTargetEffects}}" /></label>
      <label data-tooltip="{{help.techniqueConsequence}}">User Wounds <input type="number" name="system.selfWounds" value="{{system.selfWounds}}" min="0" max="99" /></label>
      <label data-tooltip="{{help.openDamage}}">Open Damage <input type="checkbox" name="system.openDamage" {{checked system.openDamage}} /></label>
      <label data-tooltip="{{help.techniqueExtraWounds}}">Extra Wounds <input type="number" name="system.extraWounds" value="{{system.extraWounds}}" min="0" max="99" /></label>
    </section>

    <section class="panel weapon-fields">
      <h2>Cathartic</h2>
      <label data-tooltip="{{help.catharticAttackModifier}}">Attack Modifier <input type="number" name="system.catharticAttackModifier" value="{{system.catharticAttackModifier}}" min="-10" max="10" /></label>
      <label data-tooltip="{{help.catharticDamageModifier}}">Damage Modifier <input type="number" name="system.catharticDamageModifier" value="{{system.catharticDamageModifier}}" min="-10" max="10" /></label>
      <label data-tooltip="{{help.directWounds}}">Direct Wounds <input type="text" name="system.catharticDirectWounds" value="{{system.catharticDirectWounds}}" /></label>
      <label data-tooltip="{{help.directWounds}}">Total Success Direct Wounds <input type="text" name="system.catharticTotalSuccessDirectWounds" value="{{system.catharticTotalSuccessDirectWounds}}" /></label>
      <label data-tooltip="{{help.targetDrains}}">Target Drain <input type="text" name="system.catharticTargetDrains" value="{{system.catharticTargetDrains}}" /></label>
      <label data-tooltip="{{help.targetDrains}}">Total Success Target Drain <input type="text" name="system.catharticTotalSuccessTargetDrains" value="{{system.catharticTotalSuccessTargetDrains}}" /></label>
      <label data-tooltip="{{help.targetEffects}}">Target Effect <input type="text" name="system.catharticTargetEffects" value="{{system.catharticTargetEffects}}" /></label>
      <label data-tooltip="{{help.targetEffects}}">Total Success Target Effect <input type="text" name="system.catharticTotalSuccessTargetEffects" value="{{system.catharticTotalSuccessTargetEffects}}" /></label>
      <label data-tooltip="{{help.techniqueConsequence}}">User Wounds <input type="number" name="system.catharticSelfWounds" value="{{system.catharticSelfWounds}}" min="0" max="99" /></label>
      <label data-tooltip="{{help.techniqueConsequence}}">Imbalance Multiplier <input type="number" name="system.catharticImbalanceMultiplier" value="{{system.catharticImbalanceMultiplier}}" min="1" max="10" /></label>
      <label data-tooltip="{{help.catharticOpenDamage}}">Open Damage <input type="checkbox" name="system.catharticOpenDamage" {{checked system.catharticOpenDamage}} /></label>
      <label data-tooltip="{{help.catharticExtraWounds}}">Cathartic Extra Wounds <input type="number" name="system.catharticExtraWounds" value="{{system.catharticExtraWounds}}" min="0" max="99" /></label>
      <label class="wide-field" data-tooltip="{{help.catharticEffect}}">Cathartic Effect <textarea name="system.catharticEffect">{{system.catharticEffect}}</textarea></label>
    </section>

    <section class="panel weapon-fields">
      <h2>Technique Notes</h2>
      <label data-tooltip="{{help.techniqueSecret}}">Secret <input type="checkbox" name="system.secret" {{checked system.secret}} /></label>
      <label data-tooltip="{{help.accessNotes}}">Access Notes <input type="text" name="system.accessNotes" value="{{system.accessNotes}}" /></label>
      <label data-tooltip="{{help.techniqueCombination}}">Combination <input type="checkbox" name="system.combination" {{checked system.combination}} /></label>
      <label data-tooltip="{{help.prerequisiteTechniques}}">Prerequisite Techniques <input type="text" name="system.prerequisiteTechniques" value="{{system.prerequisiteTechniques}}" /></label>
      <label data-tooltip="{{help.requiredFlaws}}">Required Flaws <input type="text" name="system.requiredFlaws" value="{{system.requiredFlaws}}" /></label>
      <label data-tooltip="{{help.requiredSkillRanks}}">Required Skill Ranks <input type="text" name="system.requiredSkillRanks" value="{{system.requiredSkillRanks}}" /></label>
      <label data-tooltip="{{help.requirementNotes}}">Requirement Notes <input type="text" name="system.requirementNotes" value="{{system.requirementNotes}}" /></label>
      <label data-tooltip="{{help.directWounds}}">Direct Wounds Note <input type="text" name="system.directWoundsNote" value="{{system.directWoundsNote}}" /></label>
      <label data-tooltip="{{help.targetDrains}}">Target Drain Note <input type="text" name="system.targetDrainsNote" value="{{system.targetDrainsNote}}" /></label>
      <label data-tooltip="{{help.targetEffects}}">Target Effect Note <input type="text" name="system.targetEffectsNote" value="{{system.targetEffectsNote}}" /></label>
      <label data-tooltip="{{help.techniqueConsequence}}">Consequence Note <input type="text" name="system.consequenceNote" value="{{system.consequenceNote}}" /></label>
      {{#if system.formationNotes}}
        <label data-tooltip="{{help.formationDetails}}">Formation Details <input type="text" name="system.formationNotes" value="{{system.formationNotes}}" /></label>
      {{/if}}
    </section>
  {{/if}}

  {{#if (eq item.type "combatTechnique")}}
    <section class="panel">
      <h2>Combat Perk</h2>
      <label data-tooltip="{{help.combatPerkGroup}}">Group
        <select name="system.group" data-tooltip="{{help.combatPerkGroup}}">
          <option value=""></option>
          {{#each combatTechniqueGroups as |group|}}
            <option value="{{group.key}}" data-tooltip="{{group.tooltip}}" {{#if (eq ../system.group group.key)}}selected{{/if}}>{{group.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.combatPerkSkill}}">Skill
        <select name="system.skill">
          {{#each allSkills as |skill|}}
            <option value="{{skill.key}}" {{#if (eq ../system.skill skill.key)}}selected{{/if}}>{{skill.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.combatPerkBonus}}">Bonus <input type="text" name="system.bonus" value="{{system.bonus}}" /></label>
      <label>XP Cost <input type="number" name="system.xpCost" value="{{system.xpCost}}" min="0" /></label>
      <label>Damage Effect <input type="text" name="system.damageEffect" value="{{system.damageEffect}}" /></label>
    </section>
  {{/if}}

  {{#if (eq item.type "armor")}}
    <section class="panel">
      <h2>Armor</h2>
      <label data-tooltip="{{help.armorPreset}}">Armor or Shield
        <select name="system.armorKey">
          {{#each armorRules as |armor|}}
            <option value="{{armor.key}}" data-tooltip="{{armor.tooltip}}" {{#if (eq ../system.armorKey armor.key)}}selected{{/if}}>{{armor.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.equippedArmor}}">Equipped <input type="checkbox" name="system.equipped" {{checked system.equipped}} /></label>
      <label data-tooltip="{{help.armorReduction}}">Sharp Reduction <input type="number" name="system.sharpReduction" value="{{system.sharpReduction}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.armorReduction}}">Blunt Reduction <input type="number" name="system.bluntReduction" value="{{system.bluntReduction}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.armorReduction}}">Mighty Reduction <input type="number" name="system.mightyReduction" value="{{system.mightyReduction}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.armorArrowReduction}}">Arrow Reduction <input type="number" name="system.arrowReduction" value="{{system.arrowReduction}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.armorSpeedPenalty}}">Speed Penalty <input type="number" name="system.speedPenalty" value="{{system.speedPenalty}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.armorDefenseBonus}}">Parry Bonus <input type="number" name="system.parryBonus" value="{{system.parryBonus}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.armorDefenseBonus}}">Evade Bonus <input type="number" name="system.evadeBonus" value="{{system.evadeBonus}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.muscleRequirement}}">Muscle Requirement <input type="number" name="system.muscleRequirement" value="{{system.muscleRequirement}}" min="0" max="10" /></label>
      <label>Shield <input type="checkbox" name="system.shield" {{checked system.shield}} /></label>
      <label data-tooltip="{{help.specialRules}}">Special Rules <input type="text" name="system.qualities" value="{{system.qualities}}" /></label>
    </section>
  {{/if}}

  {{#if (eq item.type "equipment")}}
    <section class="panel">
      <h2>Equipment</h2>
      <label data-tooltip="{{help.equipmentCategory}}">Category
        <select name="system.category">
          {{#each equipmentCategories as |category|}}
            <option value="{{category.key}}" {{#if (eq ../system.category category.key)}}selected{{/if}}>{{category.label}}</option>
          {{/each}}
        </select>
      </label>
      <label>Quantity <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" /></label>
      <label>Weight <input type="text" name="system.weight" value="{{system.weight}}" /></label>
    </section>
    {{#if (eq system.category "mountTransport")}}
      <section class="panel weapon-fields">
        <h2>Mount or Transport</h2>
        <label data-tooltip="{{help.transportPerformance}}">Performance Rating <input type="number" name="system.performanceRating" value="{{system.performanceRating}}" min="0" max="20" /></label>
        <label data-tooltip="{{help.transportHandling}}">Handling Speed <input type="text" name="system.handlingSpeed" value="{{system.handlingSpeed}}" /></label>
        <label>Miles per Day <input type="text" name="system.milesPerDay" value="{{system.milesPerDay}}" /></label>
        <label data-tooltip="{{help.transportSpeedScore}}">Speed Score <input type="text" name="system.speedScore" value="{{system.speedScore}}" /></label>
        <label data-tooltip="{{help.transportDefenses}}">Evade <input type="number" name="system.evade" value="{{system.evade}}" min="0" max="20" /></label>
        <label data-tooltip="{{help.transportDefenses}}">Hardiness <input type="number" name="system.hardiness" value="{{system.hardiness}}" min="0" max="20" /></label>
        <label data-tooltip="{{help.transportDefenses}}">Integrity / Health <input type="number" name="system.integrity" value="{{system.integrity}}" min="0" max="99" /></label>
        <label>Damage <input type="text" name="system.damage" value="{{system.damage}}" /></label>
      </section>
    {{/if}}
  {{/if}}

  {{#if (eq item.type "ritual")}}
    <section class="panel">
      <h2>Ritual</h2>
      <label>Activation <input type="text" name="system.activation" value="{{system.activation}}" /></label>
      <label>Requirements <input type="text" name="system.requirements" value="{{system.requirements}}" /></label>
      <label>Effects <input type="text" name="system.effects" value="{{system.effects}}" /></label>
    </section>
  {{/if}}

  {{#if (eq item.type "flaw")}}
    <section class="panel">
      <h2>Flaw</h2>
      <label data-tooltip="{{help.flawKey}}">Flaw Key
        <select name="system.flawKey" data-tooltip="{{help.flawKey}}">
          <option value=""></option>
          {{#each flawRules as |flaw|}}
            <option value="{{flaw.key}}" data-tooltip="{{flaw.tooltip}}" {{#if (eq ../system.flawKey flaw.key)}}selected{{/if}}>{{flaw.label}} ({{flaw.points}})</option>
          {{/each}}
        </select>
      </label>
      <p class="form-note">Selecting a listed flaw fills the name, category, point value, and creation-limit exemption.</p>
      <label data-tooltip="{{help.flawCategory}}">Category <input type="text" name="system.category" value="{{system.category}}" /></label>
      <label data-tooltip="{{help.flawPoints}}">Skill Point Value <input type="number" name="system.skillPointValue" value="{{system.skillPointValue}}" min="0" /></label>
      <label data-tooltip="{{help.acquiredAtCreation}}">Acquired at Creation <input type="checkbox" name="system.acquiredAtCreation" {{checked system.acquiredAtCreation}} /></label>
      <label data-tooltip="{{help.exemptFromCreationLimit}}">Exempt from Creation Limit <input type="checkbox" name="system.exemptFromCreationLimit" {{checked system.exemptFromCreationLimit}} /></label>
      <label data-tooltip="{{help.requiresResolveTest}}">Requires Resolve Test <input type="checkbox" name="system.requiresResolveTest" {{checked system.requiresResolveTest}} /></label>
      <label data-tooltip="{{help.flawPenalty}}">Penalty <input type="text" name="system.penalty" value="{{system.penalty}}" /></label>
    </section>
  {{/if}}

  {{#if (eq item.type "affliction")}}
    <section class="panel weapon-fields">
      <h2>Poison or Disease</h2>
      <label data-tooltip="{{help.afflictionType}}">Type
        <select name="system.afflictionType">
          {{#each afflictionTypes as |type|}}
            <option value="{{type.key}}" {{#if (eq ../system.afflictionType type.key)}}selected{{/if}}>{{type.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.lethality}}">Lethality
        <select name="system.lethality">
          {{#each afflictionIntervals as |interval|}}
            <option value="{{interval.key}}" {{#if (eq ../system.lethality interval.key)}}selected{{/if}}>{{interval.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.speed}}">Speed
        <select name="system.speed">
          {{#each afflictionIntervals as |interval|}}
            <option value="{{interval.key}}" {{#if (eq ../system.speed interval.key)}}selected{{/if}}>{{interval.label}}</option>
          {{/each}}
        </select>
      </label>
      <label>Effect <input type="text" name="system.effect" value="{{system.effect}}" /></label>
      <label data-tooltip="{{help.medicineTn}}">Medicine TN <input type="number" name="system.medicineTn" value="{{system.medicineTn}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.treatmentMode}}">Treatment
        <select name="system.treatmentMode">
          <option value="standard" {{#if (eq system.treatmentMode "standard")}}selected{{/if}}>Standard</option>
          <option value="staveOnly" {{#if (eq system.treatmentMode "staveOnly")}}selected{{/if}}>Stave Off Only</option>
        </select>
      </label>
      <label data-tooltip="{{help.brewRating}}">Brew Rating <input type="number" name="system.brewRating" value="{{system.brewRating}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.potency}}">Potency <input type="text" name="system.potency" value="{{system.potency}}" /></label>
      <label data-tooltip="{{help.affectedSkills}}">Affected Skills <input type="text" name="system.affectedSkills" value="{{system.affectedSkills}}" /></label>
      <label>Contagious <input type="checkbox" name="system.contagious" {{checked system.contagious}} /></label>
      <label data-tooltip="{{help.antidoteRequired}}">Remedy Required <input type="checkbox" name="system.antidoteRequired" {{checked system.antidoteRequired}} /></label>
      <label>Remedy <input type="text" name="system.remedy" value="{{system.remedy}}" /></label>
      <label>Special Rules <input type="text" name="system.specialRules" value="{{system.specialRules}}" /></label>
    </section>
  {{/if}}

  {{#if (eq item.type "substance")}}
    <section class="panel weapon-fields">
      <h2>Substance</h2>
      <label data-tooltip="{{help.substanceType}}">Category
        <select name="system.substanceType">
          {{#each substanceTypes as |type|}}
            <option value="{{type.key}}" {{#if (eq ../system.substanceType type.key)}}selected{{/if}}>{{type.label}}</option>
          {{/each}}
        </select>
      </label>
      <label data-tooltip="{{help.substanceQuantity}}">Quantity <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" /></label>
      <label data-tooltip="{{help.brewSkill}}">Creation Skill <input type="text" name="system.brewSkill" value="{{system.brewSkill}}" /></label>
      <label data-tooltip="{{help.brewTn}}">Creation TN <input type="number" name="system.brewTn" value="{{system.brewTn}}" min="0" max="10" /></label>
      <label data-tooltip="{{help.targetAffliction}}">Treats/Affects <input type="text" name="system.targetAffliction" value="{{system.targetAffliction}}" /></label>
      <label>Duration <input type="text" name="system.duration" value="{{system.duration}}" /></label>
      <label>Effects <input type="text" name="system.effects" value="{{system.effects}}" /></label>
    </section>
  {{/if}}

  <section class="panel description">
    <h2>Description</h2>
    <textarea name="system.description">{{system.description}}</textarea>
  </section>
</form>
