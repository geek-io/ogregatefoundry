<form class="ogre-gate-form actor" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" data-action="showPortraitArtwork" title="{{actor.name}}" />
    <section class="identity-grid">
      <label>Name <input type="text" name="name" value="{{actor.name}}" /></label>
      <label>Martial Name <input type="text" name="system.identity.martialName" value="{{system.identity.martialName}}" /></label>
      <label>Nickname <input type="text" name="system.identity.nickname" value="{{system.identity.nickname}}" /></label>
      <label>Sect <input type="text" name="system.identity.sect" value="{{system.identity.sect}}" /></label>
      <label>Sifu <input type="text" name="system.identity.sifu" value="{{system.identity.sifu}}" /></label>
      <label>Reputation <input type="text" name="system.identity.reputation" value="{{system.identity.reputation}}" /></label>
    </section>
    <section class="sheet-title">
      <h1>The Wandering Heroes of Ogre Gate</h1>
      <select name="system.identity.martialTier">
        <option value="martialHero" {{#if (eq system.identity.martialTier "martialHero")}}selected{{/if}}>Martial Hero</option>
        <option value="sertorius" {{#if (eq system.identity.martialTier "sertorius")}}selected{{/if}}>Sertorius</option>
        <option value="mixed" {{#if (eq system.identity.martialTier "mixed")}}selected{{/if}}>Mixed</option>
      </select>
      <label class="creation-mode-toggle" data-tooltip="{{help.creationMode}}">Creation Mode <input type="checkbox" name="system.creation.enabled" {{checked system.creation.enabled}} /></label>
    </section>
    <section class="header-vitals" aria-label="Character resources">
      <div class="vital-group">
        <h2 data-tooltip="{{help.health}}">Health</h2>
        <div class="resource-row">
          <label data-tooltip="{{help.health}}">Current <input type="number" name="system.resources.wounds.value" value="{{headerVitals.currentWounds}}" min="0" /></label>
          <label data-tooltip="{{help.health}}">Max <input type="number" name="system.resources.wounds.max" value="{{headerVitals.maxWounds}}" disabled /></label>
        </div>
        <div class="status-pill {{headerVitals.woundState}}" data-tooltip="{{help.health}}">{{headerVitals.woundState}}</div>
        {{#if system.combat.dying}}
          <label data-tooltip="{{help.dyingRounds}}">Dying Rounds <input type="number" name="system.combat.dyingRoundsElapsed" value="{{system.combat.dyingRoundsElapsed}}" min="0" /> / {{system.status.dyingRoundsMax}}</label>
        {{/if}}
      </div>

      <div class="vital-group">
        <h2>Qi</h2>
        <label data-tooltip="{{help.qiRank}}">Rank <input type="number" name="system.qi.rank" value="{{headerVitals.qiRank}}" min="0" max="12" /></label>
        <div class="metric-row" data-tooltip="{{help.drain}}"><span>Effective Qi</span><strong>{{headerVitals.effectiveQi}}</strong></div>
      </div>

      <div class="vital-group">
        <h2>Imbalance</h2>
        <div class="metric-row" data-tooltip="{{help.imbalance}}"><span>Rating</span><strong>{{system.status.imbalanceRating}}</strong></div>
        <div class="resource-row">
          <label data-tooltip="{{help.imbalance}}">Current <input type="number" name="system.imbalance.value" value="{{system.imbalance.value}}" min="0" /></label>
          <label data-tooltip="{{help.imbalance}}">Max <input type="number" name="system.imbalance.max" value="{{system.imbalance.max}}" /></label>
        </div>
        {{#if system.imbalance.possessed}}
          <div class="status-pill dying" data-tooltip="{{help.possession}}">Possessed: {{system.imbalance.spirit}}</div>
        {{/if}}
      </div>
    </section>
  </header>

  <nav class="sheet-tabs" data-group="primary">
    <a data-action="tab" data-group="primary" data-tab="front">Main</a>
    {{#if creationMode}}<a data-action="tab" data-group="primary" data-tab="creation">Creation</a>{{/if}}
    <a data-action="tab" data-group="primary" data-tab="rules">Rules</a>
    <a data-action="tab" data-group="primary" data-tab="martial">Martial</a>
    <a data-action="tab" data-group="primary" data-tab="gear">Gear</a>
    <a data-action="tab" data-group="primary" data-tab="notes">Notes</a>
  </nav>

  <section class="sheet-body">
    <div class="tab front active" data-group="primary" data-tab="front">
      <section class="roll-bar panel">
        <label data-tooltip="{{help.expertise}}">Defense Expertise <input type="checkbox" name="roll-expertise" /></label>
        <span data-tooltip="{{help.rollTn}}">Skill, defense, attack, and damage rolls prompt for TN when rolled.</span>
      </section>

      <div class="front-grid">
        <section class="panel defenses">
          <h2>Defenses</h2>
          <div class="defense-header">
            <span>Roll</span>
            <span>Defense</span>
            <span>Base</span>
            <span></span>
            <span>Rank</span>
            <span></span>
            <span>Qi</span>
            <span></span>
            <span>Mod</span>
            <span>Total</span>
          </div>
          {{#each defenses as |defense|}}
            <div class="rank-row defense-row">
              <button class="roll-icon-button" type="button" data-action="roll-defense" data-defense="{{defense.key}}" data-tooltip="{{defense.tooltip}}">{{defense.shortLabel}}</button>
              <span class="defense-label" data-tooltip="{{defense.tooltip}}">{{defense.label}}</span>
              <input type="number" name="system.defenses.{{defense.key}}.base" value="{{defense.data.base}}" />
              <span>+</span>
              <input type="number" name="system.defenses.{{defense.key}}.ranks" value="{{defense.data.ranks}}" />
              <span>+</span>
              <input type="number" name="system.defenses.{{defense.key}}.qiBonus" value="{{defense.data.qiBonus}}" />
              <span>+</span>
              <input type="number" name="system.defenses.{{defense.key}}.modifier" value="{{defense.data.modifier}}" />
              <strong>{{defense.rating}}</strong>
            </div>
            <div class="expertise-row">
              <span>Expertise</span>
              <input type="text" name="system.defenses.{{defense.key}}.expertise" value="{{defense.data.expertise}}" />
              <input type="text" name="system.defenses.{{defense.key}}.expertiseNote" value="{{defense.data.expertiseNote}}" placeholder="Condition or note" />
            </div>
          {{/each}}
          {{#if creationMode}}
          {{#if defenseBudget}}
            <div class="section-budget {{#if defenseBudget.over}}warn{{/if}}">
              <span>Creation Budget</span>
              <strong>{{defenseBudget.spent}} / {{defenseBudget.budget}}</strong>
              <span>Remaining {{defenseBudget.remaining}}</span>
            </div>
          {{/if}}
          {{/if}}
        </section>

        {{#each skillGroups as |group|}}
          <section class="panel skills {{group.key}} {{#if group.collapsed}}collapsed{{/if}}" data-skill-group="{{group.key}}">
            <div class="collapsible-heading">
              <button class="collapse-toggle" type="button" data-action="toggle-skill-group" data-group="{{group.key}}" data-tooltip="{{#if group.collapsed}}Expand{{else}}Collapse{{/if}} {{group.label}}">{{#if group.collapsed}}+{{else}}-{{/if}}</button>
              <h2>{{group.label}}</h2>
            </div>
            <div class="collapsible-content">
              <div class="item-actions compact">
                <button type="button" data-action="create-item" data-type="skills" data-group="{{group.key}}" data-tooltip="{{help.newSkill}}">New Skill</button>
              </div>
              <div class="skill-header">
                <span>Roll</span>
                <span>Skill</span>
                <span>Rank</span>
                <span>Mod</span>
                <span>Expertise</span>
                <span>Order</span>
                <span></span>
                <span></span>
              </div>
              {{#each group.skills as |skill|}}
                <div class="rank-row skill-row item-line" data-item-id="{{skill.item.id}}" data-tooltip="Right-click to edit or delete {{skill.item.name}}.">
                  <button class="roll-icon-button" type="button" data-action="roll-skill" data-item-id="{{skill.item.id}}" data-label="{{skill.displayLabel}}" data-tooltip="{{skill.tooltip}}">{{skill.shortLabel}}</button>
                  <input class="skill-label" type="text" data-item-id="{{skill.item.id}}" data-item-field="name" value="{{skill.item.name}}" />
                  <input type="number" data-item-id="{{skill.item.id}}" data-item-field="system.ranks" value="{{skill.data.ranks}}" min="0" max="10" />
                  <input type="number" data-item-id="{{skill.item.id}}" data-item-field="system.modifier" value="{{skill.data.modifier}}" min="-10" max="10" />
                  <div class="skill-expertise-cell">
                    {{#if skill.hasExpertise}}
                      <div class="skill-expertise-list">
                        {{#each skill.expertiseEntries as |expertise|}}
                          <label data-tooltip="{{expertise.note}}">
                            <input type="checkbox" data-expertise-toggle="{{expertise.toggleKey}}" data-expertise-name="{{expertise.name}}" {{checked expertise.active}} />
                            <span>{{expertise.name}}</span>
                          </label>
                        {{/each}}
                      </div>
                      <button type="button" data-action="edit-expertise" data-item-id="{{skill.item.id}}" data-label="{{skill.displayLabel}}" data-tooltip="Edit {{skill.displayLabel}} Expertise">Edit</button>
                    {{else}}
                      <button type="button" data-action="edit-expertise" data-item-id="{{skill.item.id}}" data-label="{{skill.displayLabel}}" data-tooltip="Add {{skill.displayLabel}} Expertise">+ Expertise</button>
                    {{/if}}
                  </div>
                  <div class="skill-order-buttons">
                    <button type="button" data-action="move-skill" data-direction="up" data-item-id="{{skill.item.id}}" data-tooltip="Move {{skill.item.name}} up">Up</button>
                    <button type="button" data-action="move-skill" data-direction="down" data-item-id="{{skill.item.id}}" data-tooltip="Move {{skill.item.name}} down">Down</button>
                  </div>
                  <button type="button" data-action="open-item" data-item-id="{{skill.item.id}}" data-tooltip="{{../help.editItem}}">Edit</button>
                  <button type="button" data-action="delete-item" data-item-id="{{skill.item.id}}" data-tooltip="{{../help.deleteItem}}">Delete</button>
                </div>
              {{/each}}
              {{#if ../creationMode}}
              {{#if group.budget}}
                <div class="section-budget {{#if group.budget.over}}warn{{/if}}">
                  <span>Creation Budget</span>
                  <strong>{{group.budget.spent}} / {{group.budget.budget}}</strong>
                  <span>Remaining {{group.budget.remaining}}</span>
                </div>
              {{/if}}
              {{/if}}
            </div>
          </section>
        {{/each}}

        <section class="panel text-panel">
          <h2>Flaws</h2>
          <div class="item-actions compact">
            <button type="button" data-action="create-item" data-type="flaw" data-tooltip="{{help.newFlaw}}">New Flaw</button>
          </div>
          <div class="item-list">
            {{#each flaws as |item|}}
              <div class="item-line flaw-line" data-item-id="{{item.id}}" data-tooltip="Right-click to edit or delete {{item.name}}.">
                <span>{{item.name}}</span>
                <span>{{item.system.skillPointValue}} pt</span>
                <button type="button" data-action="open-item" data-item-id="{{item.id}}" data-tooltip="{{../help.editItem}}">Edit</button>
                <button type="button" data-action="delete-item" data-item-id="{{item.id}}" data-tooltip="{{../help.deleteItem}}">Delete</button>
              </div>
            {{/each}}
          </div>
          {{#if creationMode}}
          <div class="section-budget">
            <span>Creation Flaws</span>
            <strong>{{creation.creationFlawCount}} / {{config.flawLimit.standard}}</strong>
            <span>Points {{creation.flawPoints}}</span>
          </div>
          {{/if}}
        </section>
      </div>
    </div>

    <div class="tab rules" data-group="primary" data-tab="rules">
      <div class="rules-grid">
        <section class="panel">
          <h2>Combat Round</h2>
          <label>Action
            <select name="system.combat.action" data-tooltip="Choose the combat action for movement, skill dice, and defense modifiers.">
              {{#each combatActions as |action|}}
                <option value="{{action.key}}" data-tooltip="{{action.tooltip}}" {{#if (eq ../system.combat.action action.key)}}selected{{/if}}>{{action.label}}</option>
              {{/each}}
            </select>
          </label>
          <label>Attack Mode
            <select name="system.combat.attackMode" data-tooltip="Choose the attack mode for attack dice, damage dice, wounds, and non-lethal/open damage flags.">
              {{#each attackModes as |mode|}}
                <option value="{{mode.key}}" data-tooltip="{{mode.tooltip}}" {{#if (eq ../system.combat.attackMode mode.key)}}selected{{/if}}>{{mode.label}}</option>
              {{/each}}
            </select>
          </label>
          <label data-tooltip="{{help.situationalDice}}">Situational Dice <input type="number" name="system.combat.situationalDice" value="{{system.combat.situationalDice}}" min="-10" max="10" /></label>
          <label data-tooltip="{{help.situationalDefense}}">Situational Defense <input type="number" name="system.combat.situationalDefense" value="{{system.combat.situationalDefense}}" min="-10" max="10" /></label>
          <label>Cover
            <select name="system.combat.cover" data-tooltip="Applies cover modifiers to Evade and Parry.">
              {{#each coverOptions as |cover|}}
                <option value="{{cover.key}}" data-tooltip="{{cover.tooltip}}" {{#if (eq ../system.combat.cover cover.key)}}selected{{/if}}>{{cover.label}}</option>
              {{/each}}
            </select>
          </label>
          <label>Illumination
            <select name="system.combat.illumination" data-tooltip="Applies light-level modifiers to skill dice, defenses, and Stealth.">
              {{#each illuminationOptions as |illumination|}}
                <option value="{{illumination.key}}" data-tooltip="{{illumination.tooltip}}" {{#if (eq ../system.combat.illumination illumination.key)}}selected{{/if}}>{{illumination.label}}</option>
              {{/each}}
            </select>
          </label>
          <button type="button" data-action="roll-turn-order" data-tooltip="{{help.rollTurnOrder}}">Roll Turn Order</button>
        </section>

        <section class="panel">
          <h2>Prepared Strike</h2>
          <div class="metric-row" data-tooltip="{{help.preparedStrike}}"><span>Status</span><strong>{{preparedStrikeStatus}}</strong></div>
          <label data-tooltip="{{help.preparedStrike}}">Ready <input type="checkbox" name="system.preparedStrike.ready" {{checked system.preparedStrike.ready}} /></label>
          <label data-tooltip="{{help.preparedStrike}}">Zone <input type="text" name="system.preparedStrike.zone" value="{{system.preparedStrike.zone}}" /></label>
          <label data-tooltip="{{help.preparedStrike}}">Trigger <input type="text" name="system.preparedStrike.trigger" value="{{system.preparedStrike.trigger}}" /></label>
          <div class="creation-actions">
            <button type="button" data-action="arm-prepared-strike" data-tooltip="{{help.preparedStrike}}">Arm</button>
            <button type="button" data-action="clear-prepared-strike" data-tooltip="{{help.preparedStrike}}">Clear</button>
          </div>
        </section>

        <section class="panel">
          <h2>Charge & Mounted</h2>
          <label data-tooltip="{{help.charge}}">Distance <input type="number" name="system.combat.chargeDistance" value="{{system.combat.chargeDistance}}" min="0" max="1000" /></label>
          <label data-tooltip="{{help.charge}}">Straight Line <input type="checkbox" name="system.combat.chargeStraightLine" {{checked system.combat.chargeStraightLine}} /></label>
          <label data-tooltip="{{help.charge}}">Continues Past Target <input type="checkbox" name="system.combat.mountedChargeContinues" {{checked system.combat.mountedChargeContinues}} /></label>
          <label data-tooltip="{{help.charge}}">Opponent Unmounted <input type="checkbox" name="system.combat.targetUnmounted" {{checked system.combat.targetUnmounted}} /></label>
          <label data-tooltip="{{help.charge}}">Mounted Bow Shot <input type="checkbox" name="system.combat.mountedBowShot" {{checked system.combat.mountedBowShot}} /></label>
          <label data-tooltip="{{help.charge}}">Moving Mount <input type="checkbox" name="system.combat.movingMount" {{checked system.combat.movingMount}} /></label>
          <button type="button" data-action="validate-charge" data-tooltip="{{help.charge}}">Validate</button>
        </section>

        <section class="panel" data-tooltip="{{help.qiDuel}}">
          <h2>Qi Duel</h2>
          <p class="form-note">Target one opposing actor, then resolve each contested Qi round here.</p>
          <div class="metric-row"><span>Your Effective Qi</span><strong>{{system.status.effectiveQi}}</strong></div>
          <div class="metric-row"><span>Your Neigong Rank</span><strong>{{system.disciplines.neigong.ranks}}</strong></div>
          <div class="metric-row"><span>Tied Rounds Stored</span><strong>{{system.qiDuel.ties}}</strong></div>
          <div class="metric-row"><span>Stored Extra Wounds</span><strong>+{{qiDuelStoredWounds}}</strong></div>
          <div class="creation-actions">
            <button type="button" data-action="resolve-qi-duel" data-tooltip="{{help.qiDuel}}">Resolve Round</button>
            <button type="button" data-action="clear-qi-duel" data-tooltip="Clear tied-round buildup without resolving a victor.">Clear Buildup</button>
          </div>
        </section>

        <section class="panel">
          <h2>Movement</h2>
          <div class="metric-row"><span>Land</span><strong>{{system.movement.land}} ft</strong></div>
          <div class="metric-row"><span>Swim</span><strong>{{system.movement.swim}} ft</strong></div>
          <div class="metric-row"><span>Climb</span><strong>{{system.movement.climb}} ft</strong></div>
          <div class="metric-row"><span>Fly</span><strong>{{system.movement.fly}} ft</strong></div>
        </section>

        <section class="panel">
          <h2>Damage Roll</h2>
          <label data-tooltip="{{help.pendingDamageBonus}}">Attack Total-Success Bonus <input type="number" name="system.combat.pendingDamageBonus" value="{{system.combat.pendingDamageBonus}}" min="0" max="20" /></label>
          <label data-tooltip="{{help.damageModifier}}">Damage Modifier <input type="number" name="system.combat.pendingDamageModifier" value="{{system.combat.pendingDamageModifier}}" min="-20" max="20" /></label>
          <label data-tooltip="{{help.extraWounds}}">Extra Wounds <input type="number" name="system.combat.pendingExtraWounds" value="{{system.combat.pendingExtraWounds}}" min="0" max="99" /></label>
          <label data-tooltip="{{help.openDamage}}">Open Damage <input type="checkbox" name="damage-open" /></label>
          <label data-tooltip="{{help.controlledStrike}}">Controlled Strike <input type="checkbox" name="system.combat.controlledStrike" {{checked system.combat.controlledStrike}} /></label>
        </section>

        <section class="panel">
          <h2>Healing & Dying</h2>
          <label data-tooltip="{{help.healing}}">Heal Amount <input type="number" name="system.combat.healingAmount" value="{{system.combat.healingAmount}}" min="1" max="99" /></label>
          <label data-tooltip="{{help.healing}}">Faster Healing Option <input type="checkbox" name="system.combat.fasterHealing" {{checked system.combat.fasterHealing}} /></label>
          <button type="button" data-action="heal-wounds" data-tooltip="{{help.healing}}">Heal</button>
          <button type="button" data-action="natural-healing" data-tooltip="{{help.healing}}">Natural Healing</button>
          <button type="button" data-action="stabilize-dying" data-method="medicine" data-tooltip="{{help.healing}}">Medicine TN 7</button>
          <button type="button" data-action="stabilize-dying" data-method="meditation" data-tooltip="{{help.healing}}">Meditation TN 7</button>
        </section>

        <section class="panel affliction-drop-zone" data-tooltip="{{help.affliction}}">
          <h2>Poison & Disease</h2>
          <h3>Tracked Afflictions</h3>
          <div class="affliction-substances">
            {{#if system.affliction.name}}
              <div class="metric-row">
                <span>{{system.affliction.name}}</span>
                <strong>Selected - {{system.affliction.status}}</strong>
                <button type="button" data-action="remove-selected-affliction" data-tooltip="Discard this tracker entry. This is not a cure and does not restore already applied effects.">Discard</button>
              </div>
            {{else}}
              <p class="form-note">Drop a Poison or Disease item onto the sheet to begin tracking it.</p>
            {{/if}}
            {{#each system.additionalAfflictions as |affliction|}}
              <div class="metric-row">
                <span>{{affliction.name}}</span>
                <strong>{{affliction.status}}{{#if affliction.progression}} / -{{affliction.progression}}d10{{/if}}</strong>
                <button type="button" data-action="select-affliction" data-index="{{@index}}" data-tooltip="Select {{affliction.name}} for treatment and time advancement.">Select</button>
                <button type="button" data-action="remove-additional-affliction" data-index="{{@index}}" data-tooltip="Discard this tracker entry. This is not a cure and does not restore already applied effects.">Discard</button>
              </div>
            {{/each}}
          </div>
          <label data-tooltip="{{help.affliction}}">Name <input type="text" name="system.affliction.name" value="{{system.affliction.name}}" /></label>
          <label data-tooltip="{{help.affliction}}">Type
            <select name="system.affliction.type">
              {{#each afflictionTypes as |type|}}
                <option value="{{type.key}}" {{#if (eq ../system.affliction.type type.key)}}selected{{/if}}>{{type.label}}</option>
              {{/each}}
            </select>
          </label>
          <label data-tooltip="{{help.affliction}}">Lethality
            <select name="system.affliction.lethality">
              {{#each afflictionIntervals as |interval|}}
                <option value="{{interval.key}}" {{#if (eq ../system.affliction.lethality interval.key)}}selected{{/if}}>{{interval.label}}</option>
              {{/each}}
            </select>
          </label>
          <label data-tooltip="{{help.affliction}}">Speed
            <select name="system.affliction.speed">
              {{#each afflictionIntervals as |interval|}}
                <option value="{{interval.key}}" {{#if (eq ../system.affliction.speed interval.key)}}selected{{/if}}>{{interval.label}}</option>
              {{/each}}
            </select>
          </label>
          <label data-tooltip="{{help.affliction}}">Effect <input type="text" name="system.affliction.effect" value="{{system.affliction.effect}}" /></label>
          <label data-tooltip="{{help.affliction}}">Potency <input type="text" name="system.affliction.potency" value="{{system.affliction.potency}}" /></label>
          <label data-tooltip="{{help.affliction}}">Affected Skills <input type="text" name="system.affliction.affectedSkills" value="{{system.affliction.affectedSkills}}" /></label>
          <label data-tooltip="{{help.affliction}}">Medicine TN <input type="number" name="system.affliction.medicineTn" value="{{system.affliction.medicineTn}}" min="0" max="10" /></label>
          <label data-tooltip="{{help.affliction}}">Treatment
            <select name="system.affliction.treatmentMode">
              <option value="standard" {{#if (eq system.affliction.treatmentMode "standard")}}selected{{/if}}>Standard</option>
              <option value="staveOnly" {{#if (eq system.affliction.treatmentMode "staveOnly")}}selected{{/if}}>Stave Off Only</option>
            </select>
          </label>
          <label data-tooltip="{{help.affliction}}">Cadence
            <select name="system.affliction.interval">
              {{#each afflictionIntervals as |interval|}}
                <option value="{{interval.key}}" {{#if (eq ../system.affliction.interval interval.key)}}selected{{/if}}>{{interval.label}}</option>
              {{/each}}
            </select>
          </label>
          <label data-tooltip="{{help.affliction}}">Remedy Required <input type="checkbox" name="system.affliction.antidoteRequired" {{checked system.affliction.antidoteRequired}} /></label>
          <label data-tooltip="{{help.affliction}}">Remedy Applied <input type="checkbox" name="system.affliction.antidoteApplied" {{checked system.affliction.antidoteApplied}} /></label>
          <label data-tooltip="{{help.affliction}}">Remedy <input type="text" name="system.affliction.remedy" value="{{system.affliction.remedy}}" /></label>
          <div class="metric-row"><span>Status</span><strong>{{system.affliction.status}}</strong></div>
          <div class="metric-row"><span>Contracted</span><strong>{{#if system.affliction.contracted}}Yes{{else}}No{{/if}}</strong></div>
          {{#if system.affliction.progression}}
            <div class="metric-row"><span>Cumulative Skill Penalty</span><strong>-{{system.affliction.progression}}d10</strong></div>
          {{/if}}
          {{#if system.affliction.lethalityLimit}}
            <div class="metric-row"><span>Lethality Clock</span><strong>{{system.affliction.lethalityElapsed}} / {{system.affliction.lethalityLimit}} {{system.affliction.lethality}}</strong></div>
          {{/if}}
          {{#if system.affliction.qiDrainApplied}}
            <div class="metric-row"><span>Blocked Qi</span><strong>-{{system.affliction.qiDrainApplied}}</strong></div>
          {{/if}}
          {{#if system.affliction.medicineDiceBonus}}
            <div class="metric-row"><span>Medicine Bonus</span><strong>+{{system.affliction.medicineDiceBonus}}d10</strong></div>
          {{/if}}
          {{#if system.affliction.appliedSubstances.length}}
            <h3>Applied Substances</h3>
            <div class="affliction-substances">
              {{#each system.affliction.appliedSubstances as |application|}}
                <div class="metric-row" data-tooltip="{{application.effect}}">
                  <span>{{application.name}}</span>
                  <strong>{{#if application.duration}}{{application.duration}}{{else}}Applied{{/if}}</strong>
                  {{#if application.duration}}
                    <button type="button" data-action="expire-affliction-substance" data-index="{{@index}}" data-tooltip="Expire {{application.name}} and restore values it was modifying.">Expire</button>
                  {{/if}}
                </div>
              {{/each}}
            </div>
            <button type="button" data-action="clear-affliction-substances" data-tooltip="Clear applied substances and restore the active affliction's original treatment values.">Reset Substance Effects</button>
          {{/if}}
          <label data-tooltip="{{help.affliction}}">Notes <input type="text" name="system.affliction.notes" value="{{system.affliction.notes}}" /></label>
          <div class="creation-actions">
            <button type="button" data-action="roll-affliction-exposure" data-tooltip="Roll the affliction's Potency against current Hardiness to determine whether it takes hold.">Exposure</button>
            <button type="button" data-action="advance-affliction-progression" data-tooltip="Advance one Speed interval. For Spiny Toad Venom, use only after a seizure occurs.">Advance Effect</button>
            <button type="button" data-action="advance-affliction-lethality" data-tooltip="Advance one Lethality interval toward the rolled deadline.">Advance Lethality</button>
            <button type="button" data-action="treat-affliction" data-tooltip="{{help.affliction}}">Medicine</button>
          </div>
        </section>

        <section class="panel">
          <h2>Drains</h2>
          <div class="metric-row" data-tooltip="{{help.drain}}"><span>Qi Drain</span><strong>{{system.qi.temporary}}</strong></div>
          <div class="drain-list">
            {{#each activeDrains as |drain|}}
              <div class="metric-row"><span>{{drain.label}} -{{drain.amount}}</span><strong>{{drain.note}}</strong></div>
            {{/each}}
          </div>
          <div class="creation-actions">
            <button type="button" data-action="apply-drain" data-tooltip="{{help.drain}}">Apply Drain</button>
            <button type="button" data-action="recover-drain" data-tooltip="{{help.drain}}">Recover 1 Drain</button>
          </div>
        </section>

        <section class="panel">
          <h2>Active Substances</h2>
          {{#if system.activeSubstances.length}}
            <div class="affliction-substances">
              {{#each system.activeSubstances as |application|}}
                <div class="metric-row" data-tooltip="{{application.effect}}">
                  <span>{{application.name}}</span>
                  <strong>{{#if application.duration}}{{application.duration}}{{else}}Active{{/if}}</strong>
                  <button type="button" data-action="expire-active-substance" data-index="{{@index}}" data-tooltip="End {{application.name}} and remove any roll modifier it supplies.">Expire</button>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="form-note">No duration-based substance effects are active.</p>
          {{/if}}
        </section>

        <section class="panel" data-tooltip="{{help.longevity}}">
          <h2>Longevity</h2>
          <div class="metric-row"><span>Life Prolonging Pill Course</span><strong>{{system.longevity.lifeProlongingPill.consecutiveDays}} / 10 days</strong></div>
          {{#if system.longevity.lifeProlongingPill.completed}}
            <div class="metric-row"><span>Course Completed</span><strong>Yes</strong></div>
            <div class="metric-row"><span>Lifespan Granted</span><strong>+{{system.longevity.lifeProlongingPill.yearsAdded}} years</strong></div>
            <div class="metric-row"><span>Later Uses</span><strong>{{system.longevity.lifeProlongingPill.additionalUses}}</strong></div>
            <div class="metric-row"><span>Lifespan Lost</span><strong>-{{system.longevity.lifeProlongingPill.yearsLost}} years</strong></div>
            <div class="metric-row"><span>Net Adjustment</span><strong>{{system.longevity.lifeProlongingPill.netYears}} years</strong></div>
          {{else}}
            {{#if system.longevity.lifeProlongingPill.consecutiveDays}}
              <button type="button" data-action="reset-life-pill-streak" data-tooltip="Record that the required consecutive-day course was interrupted.">Streak Broken</button>
            {{/if}}
          {{/if}}
        </section>

        <section class="panel">
          <h2>Attack Mode Reminder</h2>
          <div class="metric-row"><span>{{selectedAttackMode.label}}</span><strong>{{selectedAttackMode.workflow}}</strong></div>
        </section>

        <section class="panel">
          <h2>Hazards & Objects</h2>
          <div class="hazard-row">
            <label>Fall <input type="number" name="fall-distance" value="10" min="1" max="1000" /></label>
            <button type="button" data-action="roll-falling-damage" data-tooltip="{{help.falling}}">Falling</button>
          </div>
          <div class="hazard-row">
            <label>Fire
              <select name="fire-size">
                {{#each fireOptions as |fire|}}
                  <option value="{{fire.key}}" data-tooltip="{{fire.tooltip}}">{{fire.label}}</option>
                {{/each}}
              </select>
            </label>
            <button type="button" data-action="roll-fire-damage" data-tooltip="{{help.fire}}">Fire</button>
          </div>
          <div class="hazard-row">
            <label>Rounds <input type="number" name="suffocation-rounds" value="0" min="0" max="20" /></label>
            <button type="button" data-action="roll-suffocation" data-tooltip="{{help.suffocation}}">Suffocation</button>
          </div>
          <div class="hazard-row">
            <label>Dice <input type="number" name="object-damage-dice" value="1" min="0" max="12" /></label>
            <label>Object TN
              <select name="object-tn">
                {{#each objectTnOptions as |object|}}
                  <option value="{{object.tn}}" data-tooltip="{{object.tooltip}}">{{object.tn}} {{object.composition}}</option>
                {{/each}}
              </select>
            </label>
            <label data-tooltip="{{help.openDamage}}">Open <input type="checkbox" name="object-open" /></label>
            <button type="button" data-action="roll-object-damage" data-tooltip="{{help.objectDamage}}">Object</button>
          </div>
        </section>

        <section class="panel">
          <h2>System Rules</h2>
          <div class="metric-row" data-tooltip="{{help.systemRules}}"><span>Deep Penalties</span><strong>{{#if systemRules.deepPenalties}}On{{else}}Off{{/if}}</strong></div>
          <div class="metric-row" data-tooltip="{{help.systemRules}}"><span>Deadly 10s</span><strong>{{#if systemRules.deadlyTens}}On{{else}}Off{{/if}}</strong></div>
        </section>

        <section class="panel wide">
          <h2>Target Numbers</h2>
          <div class="tn-grid">
            {{#each config.targetNumbers as |label tn|}}
              <div><strong>{{tn}}</strong><span>{{label}}</span></div>
            {{/each}}
          </div>
        </section>

        <section class="panel wide">
          <h2>Relevant Defenses</h2>
          {{#each defenses as |defense|}}
            <div class="metric-row"><span>{{defense.label}}</span><strong>{{defense.rating}}</strong></div>
          {{/each}}
        </section>
      </div>
    </div>

    {{#if creationMode}}
    <div class="tab creation" data-group="primary" data-tab="creation">
      <div class="creation-grid">
        <section class="panel">
          <h2>Character Creation</h2>
          <label>Race
            <select name="system.creation.race" data-tooltip="Choose ancestry/race. Race effects are displayed and applied where currently automated.">
              {{#each raceOptions as |race|}}
                <option value="{{race.key}}" data-tooltip="{{race.tooltip}}" {{#if (eq ../system.creation.race race.key)}}selected{{/if}}>{{race.label}}</option>
              {{/each}}
            </select>
          </label>
          <label>Subgroup <input type="text" name="system.creation.subgroup" value="{{system.creation.subgroup}}" /></label>
          <label data-tooltip="{{help.optionalRaceApproved}}">Optional Race Approved <input type="checkbox" name="system.creation.optionalRaceApproved" {{checked system.creation.optionalRaceApproved}} /></label>
          <label data-tooltip="{{help.scholarOption}}">Scholar Option <input type="checkbox" name="system.creation.scholarOption" {{checked system.creation.scholarOption}} /></label>
          <label data-tooltip="{{help.kithiriSocialPenalty}}">Kithiri Social Penalty <input type="checkbox" name="system.creation.kithiriSocialPenalty" {{checked system.creation.kithiriSocialPenalty}} /></label>
          <label>Primary Group
            <select name="system.creation.primaryGroup1" data-tooltip="Primary groups receive the larger creation skill point budget.">
              {{#each creation.groupOptions as |group|}}
                <option value="{{group.key}}" data-tooltip="{{group.label}} receives primary-group creation budget." {{#if (eq ../system.creation.primaryGroup1 group.key)}}selected{{/if}}>{{group.label}}</option>
              {{/each}}
            </select>
          </label>
          <label>Second Primary Group
            <select name="system.creation.primaryGroup2" data-tooltip="Second primary group also receives the larger creation skill point budget.">
              {{#each creation.groupOptions as |group|}}
                <option value="{{group.key}}" data-tooltip="{{group.label}} receives primary-group creation budget." {{#if (eq ../system.creation.primaryGroup2 group.key)}}selected{{/if}}>{{group.label}}</option>
              {{/each}}
            </select>
          </label>
          <label data-tooltip="{{help.ironHeroes}}">Iron Heroes Option <input type="checkbox" name="system.creation.ironHeroes" {{checked system.creation.ironHeroes}} /></label>
          <label data-tooltip="{{help.bonusSkillPoints}}">Manual Bonus Skill Points <input type="number" name="system.creation.bonusSkillPoints" value="{{system.creation.bonusSkillPoints}}" min="0" /></label>
          <div class="creation-actions">
            <button type="button" data-action="apply-creation-defaults" data-tooltip="{{help.applyCreationDefaults}}">Apply Creation Defaults</button>
            <button type="button" data-action="add-starter-gear" data-tooltip="{{help.addStarterGear}}">Add Starter Gear</button>
            <button type="button" data-action="post-creation-summary" data-tooltip="{{help.postCreationSummary}}">Post Summary</button>
          </div>
        </section>

        <section class="panel">
          <h2>Creation Checks</h2>
          <div class="check-list">
            {{#each creation.checks as |check|}}
              <div class="check-row {{check.status}}">
                <span>{{check.label}}</span>
                <strong>{{check.current}} / {{check.target}}</strong>
              </div>
            {{/each}}
          </div>
          {{#if creation.expertiseWarnings.length}}
            <h3>Expertise Review</h3>
            <div class="warning-list">
              {{#each creation.expertiseWarnings as |warning|}}
                <p>{{warning}}</p>
              {{/each}}
            </div>
          {{/if}}
        </section>

        <section class="panel">
          <h2>Race Rules</h2>
          <label>Advantages <input type="text" value="{{creation.raceRule.advantages}}" disabled /></label>
          <label>Penalties <input type="text" value="{{creation.raceRule.penalties}}" disabled /></label>
          <label>Gift <input type="text" value="{{creation.raceRule.gift}}" disabled /></label>
          <h3>Applied Effects</h3>
          <div class="creation-list">
            {{#each creation.raceRollEffects as |effect|}}
              <p>{{effect}}</p>
            {{/each}}
          </div>
        </section>

        <section class="panel">
          <h2>Primary Groups</h2>
          <div class="creation-list">
            {{#each creation.primaryGroupLabels as |label|}}
              <p>{{label}}</p>
            {{/each}}
          </div>
          <p class="creation-note">Primary groups change the skill point budgets below. They do not add ranks by themselves.</p>
          {{#if creation.nextSteps.length}}
            <h3>Still Needed</h3>
            <div class="warning-list">
              {{#each creation.nextSteps as |step|}}
                <p>{{step}}</p>
              {{/each}}
            </div>
          {{/if}}
        </section>

        <section class="panel wide">
          <h2>Skill Point Budgets</h2>
          <div class="budget-table">
            <div class="budget-header"><span>Group</span><span>Skills</span><span>Expertise (Free)</span><span>Budget</span><span>Remaining</span></div>
            {{#each creation.groupRows as |row|}}
              <div class="budget-row {{#if row.over}}warn{{/if}}">
                <span>{{row.label}}</span>
                <span>{{row.skillSpent}}</span>
                <span>{{row.expertiseSpent}}</span>
                <span>{{row.budget}}</span>
                <strong>{{row.remaining}}</strong>
              </div>
            {{/each}}
          </div>
        </section>
      </div>
    </div>
    {{/if}}

    <div class="tab martial" data-group="primary" data-tab="martial">
      <div class="martial-grid">
        <section class="panel">
          <h2>Martial Disciplines</h2>
          <div class="discipline-header">
            <span></span>
            <span>Rank</span>
            <span>Mod</span>
          </div>
          {{#each martialDisciplines as |discipline|}}
            <div class="discipline-row">
              <span>{{discipline.label}}</span>
              <input type="number" name="system.disciplines.{{discipline.key}}.ranks" value="{{lookup (lookup ../system.disciplines discipline.key) 'ranks'}}" min="0" max="12" />
              <input type="number" name="system.disciplines.{{discipline.key}}.modifier" value="{{lookup (lookup ../system.disciplines discipline.key) 'modifier'}}" min="-10" max="10" />
            </div>
          {{/each}}
        </section>
        {{#if isGM}}
          <section class="panel">
            <h2>Karma</h2>
            <label data-tooltip="{{help.karma}}">Value <input type="number" name="system.karma.value" value="{{system.karma.value}}" min="-10" max="10" /></label>
          </section>
        {{/if}}
        <section class="panel imbalance-tools">
          <h2>Imbalance & Qi Spirits</h2>
          <div class="metric-row" data-tooltip="{{help.imbalance}}"><span>Imbalance Rating</span><strong>{{system.status.imbalanceRating}}</strong></div>
          <div class="metric-row" data-tooltip="{{help.possession}}"><span>Possession TN</span><strong>{{possessionTn}}</strong></div>
          {{#if system.imbalance.possessed}}
            <div class="metric-row"><span>Spirit</span><strong>{{system.imbalance.spirit}}</strong></div>
            <div class="metric-row"><span>Daily Control</span><strong>{{possessionControlLabel}} {{#if system.imbalance.possessionControlDays}}({{system.imbalance.possessionControlDays}} day(s)){{/if}}</strong></div>
          {{/if}}
          <div class="item-actions imbalance-actions">
            <button type="button" data-action="meditate-imbalance" data-tooltip="{{help.meditateImbalance}}">Meditate</button>
            <button type="button" data-action="check-possession" data-tooltip="{{help.possession}}">Check Possession</button>
            <button type="button" data-action="roll-demon-flaw" data-tooltip="{{help.demonFlaw}}">Roll Demon Flaw</button>
            {{#if system.imbalance.possessed}}
              <button type="button" data-action="roll-possession-control" data-tooltip="{{help.possession}}">Daily Control</button>
              <button type="button" data-action="purge-possession" data-tooltip="{{help.possession}}">Mark Purged</button>
            {{/if}}
          </div>
        </section>
        <section class="panel active-stance-panel">
          <h2>Active Stance</h2>
          {{#if activeStance}}
            <div class="metric-row" data-tooltip="{{activeStance.tooltip}}"><span>Stance</span><strong>{{activeStance.name}}</strong></div>
            <div class="metric-row"><span>Mode</span><strong>{{#if activeStance.cathartic}}Cathartic{{else}}Normal{{/if}}</strong></div>
            {{#if activeStance.cathartic}}
              <div class="metric-row"><span>Rounds Maintained</span><strong>{{activeStance.rounds}}</strong></div>
            {{/if}}
            {{#if activeStance.formation}}
              <div class="metric-row" data-tooltip="{{activeStance.formationTooltip}}"><span>Formation</span><strong>{{#if activeStance.formationParticipants}}{{activeStance.formationParticipants}}+{{else}}Yes{{/if}}</strong></div>
            {{/if}}
            {{#if activeStance.itemMissing}}
              <p class="form-note">The original stance item is missing; end this stance and re-assume it from the technique list.</p>
            {{else}}
              <p class="form-note">{{activeStance.notes}}</p>
            {{/if}}
            <div class="item-actions compact">
              {{#if activeStance.cathartic}}
                <button type="button" data-action="maintain-stance" data-tooltip="Roll the active Cathartic stance's Skill to maintain it for another round.">Maintain</button>
              {{/if}}
              <button type="button" data-action="end-stance" data-tooltip="End the active stance.">End Stance</button>
            </div>
          {{else}}
            <p class="form-note">No stance active.</p>
          {{/if}}
        </section>
        <section class="panel technique-columns">
          <h2>Kung Fu Techniques</h2>
          <div class="item-actions">
            <button type="button" data-action="create-item" data-type="technique" data-tooltip="{{help.newTechnique}}">New Kung Fu Technique</button>
            <span>Drop technique items anywhere on this sheet.</span>
          </div>
          <div class="technique-group-grid">
          {{#each techniqueGroups as |group|}}
            <div class="technique-group">
              <h3>{{label}}</h3>
              <div class="item-list">
              {{#each items as |technique|}}
                  <div class="item-line compact technique-line" data-item-id="{{technique.item.id}}">
                    <span>
                      {{technique.item.name}}
                      {{#if technique.secret}} <strong class="technique-tag" data-tooltip="Secret Technique">Secret</strong>{{/if}}
                      {{#if technique.accessNotes}} <strong class="technique-tag" data-tooltip="{{technique.accessNotes}}">Access</strong>{{/if}}
                      {{#if technique.catharticOnly}} <strong class="technique-tag" data-tooltip="Profound, Evil, and Immortal Techniques must be used Cathartically.">Cathartic Only</strong>{{/if}}
                      {{#if technique.demonFlaw}} <strong class="technique-tag warning" data-tooltip="Mastering an Evil Technique requires a Demon Flaw Table roll; the Demon Flaw is permanent.">Demon Flaw</strong>{{/if}}
                      {{#if technique.missingDiscipline}} <strong class="technique-tag warning" data-tooltip="{{technique.disciplineTooltip}}">Discipline</strong>{{/if}}
                      {{#if technique.combination}} <strong class="technique-tag" data-tooltip="{{technique.prerequisiteTooltip}}">Combination</strong>{{/if}}
                      {{#if technique.missingPrerequisites.length}} <strong class="technique-tag warning" data-tooltip="{{technique.missingPrerequisiteTooltip}}">Missing</strong>{{/if}}
                      {{#if technique.actorRequirementTooltip}} <strong class="technique-tag" data-tooltip="{{technique.actorRequirementTooltip}}">Actor Req</strong>{{/if}}
                      {{#if technique.missingActorRequirements.length}} <strong class="technique-tag warning" data-tooltip="{{technique.missingActorRequirementTooltip}}">Missing Actor</strong>{{/if}}
                      {{#if technique.requirementNotes}} <strong class="technique-tag" data-tooltip="{{technique.requirementNotes}}">Req</strong>{{/if}}
                      {{#if technique.formation}} <strong class="technique-tag" data-tooltip="{{technique.formationTooltip}}">Formation{{#if technique.formationParticipants}} {{technique.formationParticipants}}+{{/if}}</strong>{{/if}}
                    </span>
                    <span data-tooltip="Required Qi Rank; techniques do not spend Qi.">Qi {{technique.item.system.qiRank}}</span>
                    <span class="technique-damage" data-tooltip="{{technique.damage.tooltip}}">{{technique.damage.label}}</span>
                    <span class="item-row-actions">
                      <button type="button" data-action="roll-technique" data-item-id="{{technique.item.id}}" data-tooltip="{{../../help.useTechnique}}">{{#if (eq ../key "counter")}}Counter{{else if (eq ../key "stance")}}Assume{{else}}Use{{/if}}</button>
                      <button type="button" data-action="roll-technique" data-cathartic="true" data-item-id="{{technique.item.id}}" data-tooltip="{{../../help.catharticTechnique}}">Cathartic</button>
                      <button type="button" data-action="open-item" data-item-id="{{technique.item.id}}" data-tooltip="{{../../help.editItem}}">Edit</button>
                      <button type="button" data-action="delete-item" data-item-id="{{technique.item.id}}" data-tooltip="{{../../help.deleteItem}}">Delete</button>
                    </span>
                  </div>
              {{/each}}
              </div>
            </div>
          {{/each}}
          </div>
          {{#if creationMode}}
          <div class="section-budget">
            <span>Starting Kung Fu Techniques</span>
            <strong>{{creation.kungFuCount}} / {{config.creation.startingKungFuTechniques}}</strong>
            <span>Remaining {{creation.kungFuRemaining}}</span>
          </div>
          {{/if}}
        </section>
        <section class="panel combat-perk-table">
          <h2>Combat Perks</h2>
          <div class="item-actions compact">
            <button type="button" data-action="create-item" data-type="combatTechnique" data-tooltip="{{help.newCombatPerk}}">New Combat Perk</button>
          </div>
          <div class="combat-perk-header">
            <span>Name</span>
            <span>Group</span>
            <span>Skill</span>
            <span>Bonus</span>
            <span>XP</span>
            <span></span>
            <span></span>
          </div>
          <div class="item-list">
            {{#each combatTechniques as |item|}}
              <div class="combat-perk-row" data-item-id="{{item.id}}" data-tooltip="Right-click to edit or delete {{item.name}}.">
                <span>{{item.name}}</span>
                <span>{{item.system.group}}</span>
                <span>{{item.system.skill}}</span>
                <span>{{item.system.bonus}}</span>
                <span>{{item.system.xpCost}}</span>
                <button type="button" data-action="open-item" data-item-id="{{item.id}}" data-tooltip="{{../help.editItem}}">Edit</button>
                <button type="button" data-action="delete-item" data-item-id="{{item.id}}" data-tooltip="{{../help.deleteItem}}">Delete</button>
              </div>
            {{/each}}
          </div>
          {{#if creationMode}}
          <div class="section-budget">
            <span>Starting Combat Perks</span>
            <strong>{{creation.combatTechniqueCount}} / {{config.creation.startingCombatTechniques}}</strong>
            <span>Remaining {{creation.combatTechniqueRemaining}}</span>
          </div>
          {{/if}}
        </section>
      </div>
    </div>

    <div class="tab gear" data-group="primary" data-tab="gear">
      <div class="gear-grid">
        <section class="panel">
          <h2>Money</h2>
          {{#each moneyRows as |row|}}
            <label>{{row.label}} <input type="{{row.type}}" name="system.money.{{row.key}}" value="{{row.value}}" /></label>
          {{/each}}
        </section>
        <section class="panel wide">
          <h2>Equipment</h2>
          <div class="equipment-summary">
            <div class="metric-row"><span>Equipped Defense Gear</span><strong>{{equippedArmorSummary.names}}</strong></div>
            <div class="metric-row"><span>Speed Penalty</span><strong>-{{equippedArmorSummary.speedPenalty}}d10</strong></div>
            <div class="metric-row"><span>Parry / Evade</span><strong>+{{equippedArmorSummary.parryBonus}} / +{{equippedArmorSummary.evadeBonus}}</strong></div>
            <div class="metric-row"><span>Damage Reductions</span><strong>Sharp {{equippedArmorSummary.reductions.sharp}}, Blunt {{equippedArmorSummary.reductions.blunt}}, Mighty {{equippedArmorSummary.reductions.mighty}}, Arrows {{equippedArmorSummary.reductions.arrow}}</strong></div>
          </div>
          <div class="item-actions compact">
            <button type="button" data-action="create-item" data-type="equipment" data-tooltip="{{help.newGear}}">New Gear</button>
            <button type="button" data-action="create-item" data-type="substance" data-tooltip="{{help.newSubstance}}">New Substance</button>
            <span data-tooltip="{{help.equipmentDrop}}">{{help.equipmentDrop}}</span>
          </div>
          <div class="item-list equipment-drop-zone" data-tooltip="{{help.equipmentDrop}}">
            {{#each equipment as |item|}}
              <div class="item-line equipment-line" data-item-id="{{item.id}}" data-tooltip="Right-click to edit or delete {{item.name}}.">
                <span>{{item.name}}</span>
                <span>{{item.categoryLabel}}</span>
                <span>
                  {{#if item.status}}
                    {{item.status}}
                  {{else if item.quantity}}
                    Qty {{item.quantity}}
                  {{else if item.cost}}
                    Cost {{item.cost}}
                  {{/if}}
                </span>
                {{#if (eq item.type "weapon")}}
                  <button type="button" data-action="roll-weapon-attack" data-item-id="{{item.id}}" data-tooltip="{{../help.weaponAttack}}">Attack</button>
                  <button type="button" data-action="roll-weapon-damage" data-item-id="{{item.id}}" data-tooltip="{{../help.weaponDamage}}">Damage</button>
                  <button type="button" data-action="toggle-weapon-equipped" data-item-id="{{item.id}}" data-tooltip="Wield or sheathe {{item.name}}. Wielded weapons can add Parry or Evade bonuses.">{{item.equipLabel}}</button>
                {{else if (eq item.type "substance")}}
                  <button type="button" data-action="apply-substance" data-item-id="{{item.id}}" data-tooltip="Consume one dose and apply this substance's rules effect.">Use</button>
                  <span></span>
                {{else if (eq item.type "armor")}}
                  <button type="button" data-action="toggle-armor-equipped" data-item-id="{{item.id}}" data-tooltip="Equip or unequip {{item.name}}. Equipped armor and shields affect Speed, Parry, Evade, and damage reduction helpers.">{{item.equipLabel}}</button>
                  <span></span>
                {{else if item.isTransport}}
                  <button type="button" data-action="roll-transport-control" data-item-id="{{item.id}}" data-tooltip="{{../help.transportControl}}">{{item.transportSkill}}</button>
                  <button type="button" data-action="post-transport-stats" data-item-id="{{item.id}}" data-tooltip="{{../help.transportStats}}">Stats</button>
                {{else}}
                  <span></span>
                  <span></span>
                {{/if}}
                <button type="button" data-action="open-item" data-item-id="{{item.id}}" data-tooltip="{{../help.editItem}}">Edit</button>
                <button type="button" data-action="delete-item" data-item-id="{{item.id}}" data-tooltip="{{../help.deleteItem}}">Delete</button>
              </div>
            {{/each}}
          </div>
        </section>
      </div>
    </div>

    <div class="tab notes" data-group="primary" data-tab="notes">
      <div class="notes-grid">
        <section class="panel">
          <h2>Identity Notes</h2>
          <label>Player <input type="text" name="system.identity.player" value="{{system.identity.player}}" /></label>
          <label>Campaign <input type="text" name="system.identity.campaign" value="{{system.identity.campaign}}" /></label>
          <label>Homeland/Clan <input type="text" name="system.identity.homelandClan" value="{{system.identity.homelandClan}}" /></label>
          <label>Titles <input type="text" name="system.identity.titles" value="{{system.identity.titles}}" /></label>
          <label>Occupation <input type="text" name="system.identity.occupation" value="{{system.identity.occupation}}" /></label>
          <label>Family <input type="text" name="system.identity.family" value="{{system.identity.family}}" /></label>
          <label>Age <input type="text" name="system.identity.age" value="{{system.identity.age}}" /></label>
          <label>Sex <input type="text" name="system.identity.sex" value="{{system.identity.sex}}" /></label>
          <label>Height <input type="text" name="system.identity.height" value="{{system.identity.height}}" /></label>
          <label>Weight <input type="text" name="system.identity.weight" value="{{system.identity.weight}}" /></label>
        </section>
        <section class="panel">
          <h2>Family</h2>
          {{#each familyRows as |row|}}
            <label>{{row.label}} <input type="text" name="system.family.{{row.key}}" value="{{row.value}}" /></label>
          {{/each}}
        </section>
        <section class="panel">
          <h2>Biography</h2>
          <textarea name="system.notes.biography">{{system.notes.biography}}</textarea>
        </section>
        <section class="panel">
          <h2>Family Notes</h2>
          <textarea name="system.notes.family">{{system.notes.family}}</textarea>
        </section>
        <section class="panel">
          <h2>Grudges</h2>
          <textarea name="system.notes.grudges">{{system.notes.grudges}}</textarea>
        </section>
      </div>
    </div>
  </section>
</form>
