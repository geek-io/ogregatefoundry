{
  "id": "ogregatefoundry",
  "title": "The Wandering Heroes of Ogre Gate",
  "description": "A Foundry VTT v13 game system for The Wandering Heroes of Ogre Gate.",
  "version": "0.2.2",
  "url": "https://github.com/geek-io/ogregatefoundry",
  "manifest": "https://github.com/geek-io/ogregatefoundry/releases/latest/download/system.json",
